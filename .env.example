# LLM API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith for tracing (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=rfp-proposal-generator

# Database for persistence (optional - defaults to in-memory)
DATABASE_URL=postgresql://user:password@localhost:5432/rfp_db

# Federal RFP API configurations
SAM_API_KEY=your_sam_api_key_here  # For SAM.gov API

# AWS Bedrock Configuration
USE_BEDROCK=false  # Set to true to use AWS Bedrock instead of direct Anthropic API
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_SESSION_TOKEN=your_aws_session_token  # Optional, for temporary credentials

# API Server Configuration
PORT=8000
HOST=0.0.0.0